ckground":"#FFFFFF","text":"#0A0A0A"},"save":{"background":"#FFFFFF","text":"#0A0A0A"},"ok":{"background":"#F5F5F5","text":"#303030"}},"cmp":{"background":"#FFFFFF","overlay":"#303030","scrollbarThumb":"#9d9d9d"},"tabs":{"containerBackground":"#fff","tabInactive":"#0A0A0A","tabActive":"#171717"},"toggle":{"background":{"active":"#171717","inactive":"#E5E5E5","disabled":"#E5E5E5"},"handle":{"active":"#FFFFFF","inactive":"#FFFFFF","disabled":"#A3A3A3"}}}}},"screens":{"desktop":{"first":{"features":{"denyConsentsOnClose":false}},"second":{"layout":{"position":"right"},"elements":{"buttons":{"order":[["save","deny","accept"]]}},"visibility":{"hideDataProcessingServices":false,"hideServicesToggles":false,"hideLanguageSwitch":true}}},"mobile":{"base":{"elements":{"buttons":{"order":[["accept"],["deny"],["more"]]}}},"second":{"elements":{"buttons":{"order":[["accept"],["deny"],["save"]]}}}}}},"custom":{"css":"/* Card position and size */\n#uc-main-dialog.first {\n  position: fixed !important;\n  right: 24px !important;\n  bottom: 24px !important;\n  left: auto !important;\n  top: auto !important;\n  inset: auto 24px 24px auto !important;\n  transform: none !important;\n\n  width: 360px !important;\n  min-width: 360px !important;\n  max-width: 360px !important;\n  min-height: auto !important;\n\n  margin: 0 !important;\n  border-radius: 14px !important;\n  box-sizing: border-box !important;\n}\n\n/* Keep existing internal spacing, just tighten text */\n#uc-main-dialog.first #uc-privacy-title {\n  display: none !important;\n}\n\n#uc-main-dialog.first #uc-privacy-description {\n  text-align: center !important;\n  font-size: 15px !important;\n  line-height: 20px !important;\n  margin: 0 !important;\n}\n\n/* Header */\n#uc-main-dialog.first header {\n  padding-bottom: 0 !important;\n}\n\n/* Footer layout */\n#uc-main-dialog.first footer#uc-cmp-footer.bottom {\n  display: flex !important;\n  flex-direction: column-reverse !important;\n  align-items: center !important;\n  gap: 8px !important;\n  padding-top: 12px !important;\n}\n\n/* Powered by */\n#uc-main-dialog.first footer#uc-cmp-footer.bottom .left-container {\n  width: 100% !important;\n  display: flex !important;\n  justify-content: center !important;\n}\n\n#uc-main-dialog.first footer#uc-cmp-footer.bottom .poweredBy {\n  display: block !important;\n  text-align: center !important;\n  font-size: 12px !important;\n  line-height: 16px !important;\n  margin-top: 12px !important;\n  color: #737373 !important;\n}\n\n#uc-main-dialog.first footer#uc-cmp-footer.bottom .poweredBy a {\n  color: #737373 !important;\n}\n\n/* Buttons wrapper */\n#uc-main-dialog.first footer#uc-cmp-footer.bottom .buttons {\n  width: 100% !important;\n}\n\n#uc-main-dialog.first footer#uc-cmp-footer.bottom .buttons-row {\n  display: flex !important;\n  flex-direction: column !important;\n  align-items: center !important;\n  justify-content: space-between !important;\n  gap: 6px !important;\n  width: 100% !important;\n}\n\n/* Buttons */\n#uc-main-dialog.first #accept,\n#uc-main-dialog.first #more,\n#uc-main-dialog.first #deny {\n  min-height: 40px !important;\n  font-size: 14px !important;\n  border-radius: 999px !important;\n  margin: 0 !important;\n  align-self: stretch !important;\n}\n\n/* Specific widths for visual hierarchy */\n#uc-main-dialog.first #accept {\n  order: 1 !important;\n  border: 1px solid #E5E5E5 !important;\n  min-width: -moz-fit-content !important;\n  min-width: fit-content !important;\n  align-self: stretch !important;\n  font-weight: 500;\n}\n\n#uc-main-dialog.first #deny {\n  order: 3 !important;\n  border: 1px solid #E5E5E5 !important;\n  min-width: -moz-fit-content !important;\n  min-width: fit-content !important;\n  align-self: stretch !important;\n  font-weight: 500;\n}\n\n#uc-main-dialog.first #more {\n  order: 2 !important;\n  border: 1px solid #E5E5E5 !important;\n  flex: 1 1 auto !important;\n  min-width: -moz-fit-content !important;\n  min-width: fit-content !important;\n  align-self: stretch !important;\n  font-weight: 500;\n}\n\n/* SECOND LAYER: only minor button styling */\n#uc-main-dialog.second #deny,\n#uc-main-dialog.second #save,\n#uc-main-dialog.second #accept {\n  border: 1px solid #E5E5E5 !important;\n  box-shadow: none !important;\n  font-weight: 500;\n}\n\n\n/* FIRST LAYER hover states */\n#uc-main-dialog.first #more:hover,\n#uc-main-dialog.first #deny:hover {\n  background: #F5F5F5 !important;\n}\n\n#uc-main-dialog.first #accept:hover {\n  background: #F5F5F5 !important;\n}\n\n/* SECOND LAYER hover states */\n#uc-main-dialog.second #save:hover,\n#uc-main-dialog.second #deny:hover {\n  background: #F5F5F5 !important;\n}\n\n#uc-main-dialog.second #accept:hover {\n  background: #F5F5F5 !important;\n}\n\n/* ========================================\n   MOBILE FIRST LAYER\n   ======================================== */\n\n#uc-main-dialog.mobile.first {\n  position: fixed !important;\n  left: 16px !important;\n  right: 16px !important;\n  bottom: 16px !important;\n  top: auto !important;\n  inset: auto 16px 16px 16px !important;\n  transform: none !important;\n\n  width: auto !important;\n  min-width: 0 !important;\n  max-width: none !important;\n  min-height: auto !important;\n\n  margin: 0 !important;\n  border-radius: 14px !important;\n  box-sizing: border-box !important;\n}\n\n/* Hide title */\n#uc-main-dialog.mobile.first #uc-privacy-title {\n  display: none !important;\n}\n\n/* Main text */\n#uc-main-dialog.mobile.first #uc-privacy-description {\n  text-align: center !important;\n  font-size: 14px !important;\n  line-height: 20px !important;\n  margin: 0 !important;\n}\n\n/* Header */\n#uc-main-dialog.mobile.first header {\n  padding-bottom: 0 !important;\n}\n\n/* Footer */\n#uc-main-dialog.mobile.first footer#uc-cmp-footer.bottom {\n  display: flex !important;\n  flex-direction: column !important;\n  align-items: stretch !important;\n  gap: 8px !important;\n  padding-top: 12px !important;\n}\n\n/* Buttons block first */\n#uc-main-dialog.mobile.first footer#uc-cmp-footer.bottom .buttons {\n  width: 100% !important;\n  order: 1 !important;\n}\n\n/* Buttons row */\n#uc-main-dialog.mobile.first footer#uc-cmp-footer.bottom .buttons-row {\n  display: flex !important;\n  flex-direction: column !important;\n  align-items: stretch !important;\n  gap: 8px !important;\n  width: 100% !important;\n}\n\n/* Put Powered by AFTER buttons */\n#uc-main-dialog.mobile.first footer#uc-cmp-footer.bottom .left-container {\n  width: 100% !important;\n  display: contents !important;\n}\n\n#uc-main-dialog.mobile.first footer#uc-cmp-footer.bottom .poweredBy {\n  display: block !important;\n  order: 2 !important;\n  text-align: center !important;\n  font-size: 12px !important;\n  line-height: 16px !important;\n  margin-top: 12px !important;\n  color: #737373 !important;\n}\n\n#uc-main-dialog.mobile.first footer#uc-cmp-footer.bottom .poweredBy a {\n  color: #737373 !important;\n}\n\n/* Buttons */\n#uc-main-dialog.mobile.first #accept,\n#uc-main-dialog.mobile.first #more,\n#uc-main-dialog.mobile.first #deny {\n  height: 40px !important;\n  min-height: 40px !important;\n  font-size: 14px !important;\n  border-radius: 999px !important;\n  margin: 0 !important;\n  align-self: stretch !important;\n  font-weight: 500 !important;\n}\n\n/* Button order */\n#uc-main-dialog.mobile.first #accept {\n  order: 1 !important;\n  min-width: -moz-fit-content !important;\n  min-width: fit-content !important;\n  align-self: stretch !important;\n}\n\n#uc-main-dialog.mobile.first #more {\n  order: 2 !important;\n  border: 1px solid #E5E5E5 !important;\n  flex: 1 1 auto !important;\n  min-width: -moz-fit-content !important;\n  min-width: fit-content !important;\n  align-self: stretch !important;\n}\n\n#uc-main-dialog.mobile.first #deny {\n  order: 3 !important;\n  border: 1px solid #E5E5E5 !important;\n  min-width: -moz-fit-content !important;\n  min-width: fit-content !important;\n  align-self: stretch !important;\n}\n\n/* ========================================\n   SECOND LAYER\n   Minor tweaks only\n   ======================================== */\n\n#uc-main-dialog.second #deny,\n#uc-main-dialog.second #save {\n  border: 1px solid #E5E5E5 !important;\n  box-shadow: none !important;\n  font-weight: 500 !important;\n}\n\n#uc-main-dialog.second #accept {\n  font-weight: 500 !important;\n}\n\n#uc-main-dialog.second {\n  --color-tabs-tab-active: #171717 !important;\n}\n\n#uc-main-dialog.second .sections-header>div.active {\n  color: #171717 !important;\n  border-bottom: 2px solid #171717 !important;\n}\n\n/* SECOND LAYER: bigger buttons + larger gaps */\n#uc-main-dialog.second footer#uc-cmp-footer.bottom .buttons {\n  width: 100% !important;\n}\n\n#uc-main-dialog.second footer#uc-cmp-footer.bottom .buttons-row {\n  display: flex !important;\n  align-items: center !important;\n  gap: 8px !important;\n  width: 100% !important;\n}\n\n#uc-main-dialog.second #accept,\n#uc-main-dialog.second #deny,\n#uc-main-dialog.second #save {\n  min-height: 40px !important;\n  height: 40px !important;\n  font-weight: 500 !important;\n}"}},"consent":{"controllerId":"","createdAt":0,"language":"en","required":false,"setting":{"id":"VeSOqyHdbTBKk9","version":"17.1.49","type":"GDPR"},"updatedAt":0,"updatedBy":"onInitialPageLoad","type":"IMPLICIT","version":1,"status":"ALL_DENIED","hash":"","serviceIds":[]},"i18n":{"categories":{"marketing":{"description":"These technologies are used by advertisers to serve ads that are relevant to your interests.","name":"Marketing","id":"marketing"},"functional":{"description":"These technologies enable us to analyse usage behavior in order to measure and improve performance.","name":"Functional","id":"functional"},"essential":{"description":"These technologies are required to activate the core functionality of our service.","name":"Essential","id":"essential"}},"services":{"H1Vl5NidjWX":{"description":"","id":"H1Vl5NidjWX","legalBasis":[],"name":"Usercentrics Consent Management Platform"},"BJz7